{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "budget-app",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3456", "."],
      "port": 3456
    },
    {
      "name": "Backend API (Express + Socket.IO)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "togo-edu-platform/backend",
      "port": 5000
    },
    {
      "name": "Frontend Web (React.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "togo-edu-platform/frontend/web",
      "port": 3000
    },
    {
      "name": "Mobile (Expo / React Native)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "togo-edu-platform/frontend/mobile",
      "port": 8081
    }
  ]
}
